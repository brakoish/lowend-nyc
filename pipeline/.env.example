# Google Sheets API
GOOGLE_CREDENTIALS_PATH=~/.config/lowend-nyc/google-credentials.json
GOOGLE_SHEET_ID=your-google-sheet-id-here

# GitHub
GITHUB_TOKEN=ghp_your_token_here
GITHUB_REPO=brakoish/lowend-nyc
GITHUB_BRANCH=main

# Discord Notifications
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# OpenClaw (for agent spawning)
# These are used internally by the orchestrator
OPENCLAW_WORKSPACE=~/.openclaw/workspace-lowend-nyc

# Pipeline Settings
PIPELINE_CHECK_INTERVAL_MINUTES=5
PIPELINE_PUBLISH_HOUR=9
PIPELINE_TIMEZONE=America/New_York
